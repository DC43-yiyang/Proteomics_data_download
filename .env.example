# NCBI API Key (optional, increases rate limit from 3 to 10 req/s)
# Get yours at: https://www.ncbi.nlm.nih.gov/account/ -> Settings -> API Key Management
NCBI_API_KEY=
NCBI_EMAIL=

# Anthropic API Key (required for --library-type sample classification)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# LLM model for sample classification (default: claude-haiku-4-5-20251001)
LLM_MODEL=claude-haiku-4-5-20251001
