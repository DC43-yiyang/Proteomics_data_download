# NCBI API Key (optional, increases rate limit from 3 to 10 req/s)
# Get yours at: https://www.ncbi.nlm.nih.gov/account/ -> Settings -> API Key Management
NCBI_API_KEY=
NCBI_EMAIL=

# ============================================================================
# Multi-omics annotation LLM configuration
# ============================================================================

# LLM Provider: ollama | deepseek | qwen | kimi | minimax | openai
LLM_PROVIDER=ollama

# API Key (required for non-ollama providers)
LLM_API_KEY=

# Base URL (optional, uses provider default if not specified)
LLM_BASE_URL=

# Model name for annotation (provider-specific)
# - ollama:   qwen3:30b-a3b (default)
# - deepseek: deepseek-chat, deepseek-reasoner
# - qwen:     qwen-plus, qwen-turbo, qwen-max
# - kimi:     moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
# - minimax:  abab6.5-chat, abab6.5s-chat
# - openai:   gpt-4o, gpt-4o-mini
LLM_ANNOTATION_MODEL=qwen3:30b-a3b

# ============================================================================
# Provider Examples (uncomment to use)
# ============================================================================

# DeepSeek (Recommended for Cost: ~¥1/M input, ¥2/M output)
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-your-deepseek-key
# LLM_ANNOTATION_MODEL=deepseek-chat

# Qwen (Alibaba Cloud)
# LLM_PROVIDER=qwen
# LLM_API_KEY=sk-your-qwen-key
# LLM_ANNOTATION_MODEL=qwen-plus

# Kimi (Moonshot, Long Context)
# LLM_PROVIDER=kimi
# LLM_API_KEY=sk-your-kimi-key
# LLM_ANNOTATION_MODEL=moonshot-v1-32k

# MiniMax
# LLM_PROVIDER=minimax
# LLM_API_KEY=your-minimax-key
# LLM_ANNOTATION_MODEL=abab6.5-chat
