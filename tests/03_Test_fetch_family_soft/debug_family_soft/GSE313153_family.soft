^SERIES = GSE313153
!Series_title = CITE-seq profiling of human splenic dendritic cells
!Series_geo_accession = GSE313153
!Series_status = Public on Feb 23 2026
!Series_submission_date = Dec 10 2025
!Series_last_update_date = Feb 23 2026
!Series_pubmed_id = 41713421
!Series_summary = To depict a comprehensive atlas of human splenic DCs and investigate DC2hm in a broad context, we performed Cellular Indexing of Transcriptomes and Epitopes by Sequencing (CITE-seq) using a panel of 151 oligo-conjugated antibodies recognizing surface proteins on Lin [CD3/CD19/NKp46]â»CD66bâ» CD88â»CD89â»HLA-DRâº splenocytes from two donors. This dataset identified nearly all currently recognized human splenic DC subsets. Integrated transcriptomic- and protein-level analyses support the conclusion that DC2hm represents a homeostatic maturation state originating from cDC2 and is distinct from other DC lineages.
!Series_overall_design = Lin[CD3/CD19/CD56]â»CD89â»CD66bâ»CD88â»HLA-DRâº splenocytes from non-diseased adult human donors (trauma-induced splenectomy cases)
