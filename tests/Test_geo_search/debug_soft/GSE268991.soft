^SERIES = GSE268991
!Series_title = Transcriptional profile and TCR sequences from tumor and adjacent normal human colorectal samples
!Series_geo_accession = GSE268991
!Series_status = Public on Feb 15 2026
!Series_submission_date = Jun 03 2024
!Series_last_update_date = Feb 16 2026
!Series_summary = We focus on characterizing mucosal-resident Î³Î´ T cells for determination of their effector profile, characterization of their paired TCR repertoire, and understanding of antigen reactivity towards CD1 molecules through single cell RNA analyses.
!Series_overall_design = Intestinal epithelial lymphocytes (IEL) from tumor or adjacent normal tissue from human colon were isolated. Gamma delta T cells were sorted from whole IEL using Vd1 and Vd2 antibodies and/or tetramers of CD1d or MR1. Four 10x Genomics libraries were then made from each sample: gene expression, surface (CITE-seq), alpha beta TCR, and gamma delta TCR.
!Series_type = Expression profiling by high throughput sequencing
!Series_type = Other
