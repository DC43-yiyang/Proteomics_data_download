!Sample_supplementary_file_1 = ftp://ftp.ncbi.nlm.nih.gov/geo/samples/GSM9140nnn/GSM9140269/suppl/GSM9140269_VAC012_1_vdj_t_contig.csv.gz
!Sample_series_id = GSE303984
