!Sample_contact_city = Milwaukee
!Sample_contact_zip/postal_code = 53226
!Sample_contact_country = USA
!Sample_instrument_model = Illumina NovaSeq 6000
!Sample_library_selection = cDNA
!Sample_library_source = transcriptomic single cell
!Sample_library_strategy = RNA-Seq
!Sample_relation = BioSample: https://www.ncbi.nlm.nih.gov/biosample/SAMN45502291
!Sample_relation = SRA: https://www.ncbi.nlm.nih.gov/sra?term=SRX27031845
